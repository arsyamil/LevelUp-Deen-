{
  "name": "level-up-deen",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9 <25",
    "npm": ">=10"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify:workflow": "node scripts/verify-workflow.js",
    "smoke:local": "node scripts/smoke-deploy.js --base=http://localhost:3000 --api-base=http://localhost:8000",
    "smoke:prod": "node scripts/smoke-deploy.js --base=https://level-up-deen.vercel.app",
    "check": "npm run verify:workflow && npm run lint && npm run typecheck && npm run build",
    "clean": "rm -rf .next tsconfig.tsbuildinfo",
    "doctor": "npm run typecheck && npm run test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "canvas-confetti": "^1.9.4",
    "expr-eval": "^2.0.2",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "three": "^0.184.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "jsdom": "^29.1.1",
    "postcss": "8.5.15",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  }
}
