# ===========================================
# Level Up Deen - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# cp .env.local.example .env.local

# -------------------------------------------
# Clerk Auth (Required)
# -------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key
CLERK_SECRET_KEY=sk_test_your-secret-key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# -------------------------------------------
# Supabase Persistence (Required)
# -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -------------------------------------------
# App Configuration (Required)
# -------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# -------------------------------------------
# Development Auth Bypass (Optional)
# -------------------------------------------
# Use only for local feature review while Clerk OAuth is unavailable.
AUTH_BYPASS_ENABLED=false
AUTH_BYPASS_USER_ID=dev-demo-user
AUTH_BYPASS_ROLE=admin_system

# -------------------------------------------
# Google OAuth (Optional)
# -------------------------------------------
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# -------------------------------------------
# AI Features - v1.1 (Optional)
# -------------------------------------------
# OPENAI_API_KEY=sk-your-openai-key
# AI_GATEWAY_URL=https://your-ai-gateway.com
# AI_RATE_LIMIT_CHAT=20
# AI_RATE_LIMIT_FINANCE=30
