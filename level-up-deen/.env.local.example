# ===========================================
# Level Up Deen - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# cp .env.local.example .env.local

# -------------------------------------------
# Supabase (Required - Auth + Database)
# -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -------------------------------------------
# App Configuration (Required)
# -------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# -------------------------------------------
# Development Auth Bypass (Optional)
# -------------------------------------------
# Use only for local feature review while Supabase Auth is unavailable.
AUTH_BYPASS_ENABLED=false
AUTH_BYPASS_USER_ID=dev-demo-user
AUTH_BYPASS_ROLE=admin_system

# -------------------------------------------
# AI Features (Optional)
# -------------------------------------------
# GEMINI_API_KEY=your-gemini-api-key
